# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_LOG_LEVEL=INFO
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=example.com,www.example.com

# Database (PostgreSQL)
DB_NAME=alahly
DB_USER=alahly
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Sentry (error tracking)
SENTRY_DSN=https://your-dsn@ingest.sentry.io/your-project
SENTRY_TRACES_SAMPLE_RATE=0.1

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_AUTO_SEND_ENABLED=False

# Firebase Cloud Messaging
FCM_CREDENTIALS_PATH=/path/to/firebase-adminsdk-credentials.json

# Bank Account Details (for bank transfer payments)
BANK_ACCOUNT_NUMBER=000-123456-789
BANK_IBAN=LY123456789012345678901234

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@alahly.sport
