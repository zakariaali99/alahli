# Mobile App Environment Variables
# Pass these as dart-define flags at build time:
#   flutter run --dart-define=API_BASE_URL=http://your-server:8000/api
#   flutter build apk --release --dart-define=API_BASE_URL=https://api.yourdomain.com/api

# Backend API base URL (REQUIRED for production)
# Default is a local network IP that only works on LAN — override for any real deployment
API_BASE_URL=https://alahlicenter.ly/api

# Android release signing
# Do not commit real signing values. Store them in CI/CD secrets or local key.properties.
ANDROID_KEY_ALIAS=release
ANDROID_KEYSTORE_PATH=android/app/release-keystore.jks
